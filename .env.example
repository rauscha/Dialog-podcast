ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...

# GitHub — required to trigger Actions workflow from the email webhook
GH_TOKEN=ghp_...
GITHUB_USER=your-github-username
GITHUB_REPO=dialog-podcast

# Webhook server
WEBHOOK_SECRET=some-random-secret
ALLOWED_SENDERS=you@example.com

# Local development
PODCAST_REPO_PATH=C:\Dialog-podcast
SKIP_GIT=1

# Set to "false" to disable MusicGen (CI sets this automatically)
USE_MUSIC=true

# Voice overrides (optional — values come from config.json by default)
HOST_A_VOICE=cedar
HOST_B_VOICE=marin
